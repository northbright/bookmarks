<p><strong>Key Points:</strong></p>

<ul>
<li>The Initialization Vector (IV) is randomly generated for each encryptio=
n, adding an extra layer of security.</li>
<li>The encryption process uses AES in CBC (Cipher Block Chaining) mode, ma=
king it more secure by using the IV along with the secret key.</li>
<li>The result is encoded in Base64 for safe transmission in URLs.</li>
</ul>

<p><strong>AES Decryption Function</strong><br>
</p>

<div class=3D"highlight js-code-highlight">
<pre class=3D"highlight plaintext"><code>const decryptWithSecretKey =3D (en=
cryptedText) =3D&gt; {
  try {
    const fullCipher =3D CryptoJS.enc.Base64.parse(encryptedText);

    // Extract IV and ciphertext from the parsed cipher
    const iv =3D CryptoJS.lib.WordArray.create(fullCipher.words.slice(0, 4)=
, 16);
    const ciphertext =3D CryptoJS.lib.WordArray.create(fullCipher.words.sli=
ce(4));

    const cipherParams =3D CryptoJS.lib.CipherParams.create({
      ciphertext: ciphertext,
    });

    // Fetch and parse the secret key from environment variables
    const secretKey =3D process.env.NEXT_PUBLIC_SECRET_KEY?.replace(
      /\\n/g,
      "\n"
    );

    // Decrypt the ciphertext using AES and the provided secret key
    const decrypted =3D CryptoJS.AES.decrypt(
      cipherParams,
      CryptoJS.enc.Hex.parse(secretKey),
      {
        iv: iv,
        padding: CryptoJS.pad.Pkcs7,
        mode: CryptoJS.mode.CBC,
      }
    );

    // Return decrypted text in UTF-8 format
    return decrypted.toString(CryptoJS.enc.Utf8);
  } catch (error) {
    console.error("Decryption error:", error);
    return;
  }
};
</code></pre>
