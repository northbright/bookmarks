        }
   =20
        <span class=3D"hljs-comment">// scraping logic</span>
        <span class=3D"hljs-keyword">var</span> name, price <span class=3D"=
hljs-keyword">string</span>
        <span class=3D"hljs-keyword">for</span> _, node :=3D <span class=3D=
"hljs-keyword">range</span> productNodes {
           <span class=3D"hljs-comment">// extract data from the product HT=
ML node</span>
           err =3D chromedp.Run(ctx,
              chromedp.Text(<span class=3D"hljs-string">"h4"</span>, &amp;n=
ame, chromedp.ByQuery, chromedp.FromNode(node)),
              chromedp.Text(<span class=3D"hljs-string">"h5"</span>, &amp;p=
rice, chromedp.ByQuery, chromedp.FromNode(node)),
           )
   =20
           <span class=3D"hljs-keyword">if</span> err !=3D <span class=3D"h=
ljs-literal">nil</span> {
              log.Fatal(<span class=3D"hljs-string">"Error:"</span>, err)
           }
   =20
           <span class=3D"hljs-comment">// initialize a new product instanc=
e</span>
           <span class=3D"hljs-comment">// with scraped data</span>
           product :=3D Product{}
           product.name =3D name
           product.price =3D price
   =20
           products =3D <span class=3D"hljs-built_in">append</span>(product=
s, product)
        }
   =20
        fmt.Println(products)
    }
</code></pre>
