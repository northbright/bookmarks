.skeleton { background-size: 300%; animation: 3s ease 0s infinite normal no=
ne running AnimationName; }

@keyframes AnimationName {=20
  0%, 100% { background-position: 0% center; }
  50% { background-position: 100% center; }
}

.animate-slide-fade-out-left { opacity: 0; width: 0%; transition: width 0.3=
s cubic-bezier(0.6, 0.6, 0, 1) 0.3s, opacity 0.3s ease 0.3s; animation: 0.3=
s cubic-bezier(0.6, 0.6, 0, 1) 0s 1 normal forwards running slideLeftOut; }

.animate-slide-fade-in-right { opacity: 1; transition: width 0.3s cubic-bez=
ier(0.6, 0.6, 0, 1) 0.3s, opacity 0.3s ease 0.3s; animation: 0.3s cubic-bez=
ier(0.6, 0.6, 0, 1) 0s 1 normal forwards running slideRightIn; }

@keyframes slideLeftOut {=20
  0% { transform: translate(0px); }
  100% { transform: translate(-15rem); }
}

@keyframes slideRightIn {=20
  0% { transform: translate(-15rem); }
  100% { transform: translate(0px); }
}

.animate-slide-fade-out-right { opacity: 0; width: 0%; transition: width 0.=
3s cubic-bezier(0.6, 0.6, 0, 1) 0.3s, opacity 0.3s ease 0.3s; animation: 0.=
3s cubic-bezier(0.6, 0.6, 0, 1) 0s 1 normal forwards running slideRightOut;=
 }

.animate-slide-fade-in-left { opacity: 1; transition: width 0.3s cubic-bezi=
er(0.6, 0.6, 0, 1) 0.3s, opacity 0.3s ease 0.3s; animation: 0.3s cubic-bezi=
er(0.6, 0.6, 0, 1) 0s 1 normal forwards running slideLeftIn; }

@keyframes slideRightOut {=20
  0% { transform: translate(0px); }
  100% { transform: translate(20.875rem); }
}

@keyframes slideLeftIn {=20
  0% { transform: translate(20.875rem); }
  100% { transform: translate(0px); }
}

@keyframes sparkle {=20
  0% { transform: scale(1) rotate(0deg); }
  25% { transform: scale(0.9) rotate(-8deg); }
  50% { transform: scale(1) rotate(0deg); }
  75% { transform: scale(0.9) rotate(8deg); }
  100% { transform: scale(1) rotate(0deg); }
}

.sparkle { transform-origin: 50% center; transform-box: fill-box; animation=
: 2.4s cubic-bezier(0.6, 0.6, 0, 1) 0s infinite normal none running sparkle=
; }

