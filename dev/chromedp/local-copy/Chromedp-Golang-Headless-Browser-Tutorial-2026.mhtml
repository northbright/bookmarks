            <pre><code class=3D"language-go hljs go" data-lang=3D"go">    <=
span class=3D"hljs-keyword">package</span> main
   =20
    <span class=3D"hljs-keyword">import</span> (
        <span class=3D"hljs-string">"context"</span>
        <span class=3D"hljs-string">"fmt"</span>
        <span class=3D"hljs-string">"github.com/chromedp/cdproto/dom"</span=
>
        <span class=3D"hljs-string">"github.com/chromedp/chromedp"</span>
        <span class=3D"hljs-string">"log"</span>
        <span class=3D"hljs-string">"time"</span>
    )
   =20
    <span class=3D"hljs-function"><span class=3D"hljs-keyword">func</span> =
<span class=3D"hljs-title">main</span><span class=3D"hljs-params">()</span>=
</span> {
        <span class=3D"hljs-comment">// initialize a controllable Chrome in=
stance</span>
        ctx, cancel :=3D chromedp.NewContext(
           context.Background(),
        )
        <span class=3D"hljs-comment">// to release the browser resources wh=
en</span>
        <span class=3D"hljs-comment">// it is no longer needed</span>
        <span class=3D"hljs-keyword">defer</span> cancel()
   =20
        <span class=3D"hljs-keyword">var</span> html <span class=3D"hljs-ke=
yword">string</span>
        err :=3D chromedp.Run(ctx,
           <span class=3D"hljs-comment">// visit the target page</span>
           chromedp.Navigate(<span class=3D"hljs-string">"https://scrapingc=
lub.com/exercise/list_infinite_scroll/"</span>),
           <span class=3D"hljs-comment">// wait for the page to load</span>
           chromedp.Sleep(<span class=3D"hljs-number">2000</span>*time.Mill=
isecond),
           <span class=3D"hljs-comment">// extract the raw HTML from the pa=
ge</span>
           chromedp.ActionFunc(<span class=3D"hljs-function"><span class=3D=
"hljs-keyword">func</span><span class=3D"hljs-params">(ctx context.Context)=
</span> <span class=3D"hljs-title">error</span></span> {
              <span class=3D"hljs-comment">// select the root node on the p=
age</span>
              rootNode, err :=3D dom.GetDocument().Do(ctx)
              <span class=3D"hljs-keyword">if</span> err !=3D <span class=
=3D"hljs-literal">nil</span> {
                 <span class=3D"hljs-keyword">return</span> err
              }
              html, err =3D dom.GetOuterHTML().WithNodeID(rootNode.NodeID).=
Do(ctx)
              <span class=3D"hljs-keyword">return</span> err
           }),
        )
        <span class=3D"hljs-keyword">if</span> err !=3D <span class=3D"hljs=
-literal">nil</span> {
           log.Fatal(<span class=3D"hljs-string">"Error while performing th=
e automation logic:"</span>, err)
        }
   =20
        fmt.Println(html)
    }
</code></pre>
