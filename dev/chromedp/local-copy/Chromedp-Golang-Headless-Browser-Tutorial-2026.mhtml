                        <h3 class=3D"h4 font-title text-dark mb-8" style=3D=
"scroll-margin-top: 100px" id=3D"file-download-using-chromedp">File Downloa=
d Using Chromedp</h3>
<p class=3D"mb-8 last:mb-0">Chromedp offers methods to download both an ima=
ge on the page or a specific file from a button or link.
See the snippet below to download an image:</p>
           =20
       =20
           =20
       =20
                    <div class=3D"mt-4 code-block-with-header relative" dat=
a-id=3D"content-block__code-header-77">
                <div class=3D"bg-inactive text-gray text-base py-3 px-5 rou=
nded-t-lg">
                    scraper.go
                </div>
       =20
        <div class=3D"mb-8 text-sm " id=3D"_SUn9uk4KKbw4ZrxQ5UeM" data-id=
=3D"content-block__code-77">
            <pre><code class=3D"language-go hljs go" data-lang=3D"go">    <=
span class=3D"hljs-comment">// initialize a download channel</span>
    done :=3D <span class=3D"hljs-built_in">make</span>(<span class=3D"hljs=
-keyword">chan</span> <span class=3D"hljs-keyword">bool</span>)
   =20
    <span class=3D"hljs-comment">// this will be used to capture the reques=
t id</span>
    <span class=3D"hljs-comment">// for matching network events</span>
    <span class=3D"hljs-keyword">var</span> requestID network.RequestID
   =20
    <span class=3D"hljs-comment">// set up a listener to watch the network =
events and close the channel when</span>
    <span class=3D"hljs-comment">// the desired request completes</span>
    chromedp.ListenTarget(ctx, <span class=3D"hljs-function"><span class=3D=
"hljs-keyword">func</span><span class=3D"hljs-params">(v <span class=3D"hlj=
s-keyword">interface</span>{})</span></span> {
        <span class=3D"hljs-keyword">switch</span> ev :=3D v.(<span class=
=3D"hljs-keyword">type</span>) {
        <span class=3D"hljs-keyword">case</span> *network.EventRequestWillB=
eSent:
           log.Printf(<span class=3D"hljs-string">"EventRequestWillBeSent: =
%v: %v"</span>, ev.RequestID, ev.Request.URL)
           <span class=3D"hljs-keyword">if</span> ev.Request.URL =3D=3D url=
str {
              requestID =3D ev.RequestID
           }
        <span class=3D"hljs-keyword">case</span> *network.EventLoadingFinis=
hed:
           log.Printf(<span class=3D"hljs-string">"EventLoadingFinished: %v=
"</span>, ev.RequestID)
           <span class=3D"hljs-keyword">if</span> ev.RequestID =3D=3D reque=
stID {
              <span class=3D"hljs-built_in">close</span>(done)
           }
        }
    })
   =20
    <span class=3D"hljs-comment">// all we need to do here is navigate to t=
he download url</span>
    err :=3D chromedp.Run(ctx,
        chromedp.Navigate(<span class=3D"hljs-string">"https://example.com/=
image"</span>),
    )
   =20
    <span class=3D"hljs-keyword">if</span> err !=3D <span class=3D"hljs-lit=
eral">nil</span> {
        log.Fatal(<span class=3D"hljs-string">"Error:"</span>, err)
    }
   =20
    <span class=3D"hljs-comment">// this will block the execution</span>
    <span class=3D"hljs-comment">// until the chromedp listener closes the =
channel</span>
    &lt;-done
    <span class=3D"hljs-comment">// get the downloaded bytes for the reques=
t id</span>
    <span class=3D"hljs-keyword">var</span> imageBuffer []<span class=3D"hl=
js-keyword">byte</span>
    err =3D chromedp.Run(ctx, chromedp.ActionFunc(<span class=3D"hljs-funct=
ion"><span class=3D"hljs-keyword">func</span><span class=3D"hljs-params">(c=
tx context.Context)</span> <span class=3D"hljs-title">error</span></span> {
        <span class=3D"hljs-keyword">var</span> err error
        imageBuffer, err =3D network.GetResponseBody(requestID).Do(ctx)
        <span class=3D"hljs-keyword">return</span> err
    }))
    <span class=3D"hljs-keyword">if</span> err !=3D <span class=3D"hljs-lit=
eral">nil</span> {
        log.Fatal(<span class=3D"hljs-string">"Error:"</span>, err)
    }
   =20
    <span class=3D"hljs-comment">// write the image file to disk</span>
    err =3D os.WriteFile(<span class=3D"hljs-string">"download.png"</span>,=
 imageBuffer, <span class=3D"hljs-number">0644</span>)
    <span class=3D"hljs-keyword">if</span> err !=3D <span class=3D"hljs-lit=
eral">nil</span> {
        log.Fatal(<span class=3D"hljs-string">"Error:"</span>, err)
    }
</code></pre>
