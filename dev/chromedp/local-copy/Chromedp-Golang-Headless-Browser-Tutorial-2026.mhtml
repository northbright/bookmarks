        <div class=3D"mb-8 text-sm " id=3D"_9rTkJgkIubMJYIgqv8dl" data-id=
=3D"content-block__code-55">
            <pre><code class=3D"language-javascript hljs javascript" data-l=
ang=3D"javascript">
    package main
   =20
    <span class=3D"hljs-keyword">import</span> (
        <span class=3D"hljs-string">"context"</span>
        <span class=3D"hljs-string">"fmt"</span>
        <span class=3D"hljs-string">"github.com/chromedp/cdproto/cdp"</span=
>
        <span class=3D"hljs-string">"github.com/chromedp/chromedp"</span>
        <span class=3D"hljs-string">"log"</span>
        <span class=3D"hljs-string">"time"</span>
    )
   =20
    <span class=3D"hljs-comment">// Product data structure to store the scr=
aped data</span>
    type Product struct {
        name, price string
    }
   =20
    func main() {
        <span class=3D"hljs-comment">// to keep track of all the scraped ob=
jects</span>
        <span class=3D"hljs-keyword">var</span> products []Product
   =20
        <span class=3D"hljs-comment">// initialize a controllable Chrome in=
stance</span>
        ctx, <span class=3D"hljs-attr">cancel</span> :=3D chromedp.NewConte=
xt(
           context.Background(),
        )
        <span class=3D"hljs-comment">// to release the browser resources wh=
en</span>
        <span class=3D"hljs-comment">// it is no longer needed</span>
        defer cancel()
   =20
        <span class=3D"hljs-comment">// scrolling logic in JavaScript</span=
>
        <span class=3D"hljs-attr">scrollingScript</span> :=3D <span class=
=3D"hljs-string">`
           // scroll down the page 8 times
           const scrolls =3D 8
           let scrollCount =3D 0
          =20
           // scroll down and then wait for 0.5s
           const scrollInterval =3D setInterval(() =3D&gt; {
             window.scrollTo(0, document.body.scrollHeight)
             scrollCount++
          =20
             if (scrollCount =3D=3D=3D numScrolls) {
              clearInterval(scrollInterval)
             }
           }, 500)
        `</span>
   =20
        <span class=3D"hljs-comment">// browser automation logic</span>
        <span class=3D"hljs-keyword">var</span> productNodes []*cdp.Node
        <span class=3D"hljs-attr">err</span> :=3D chromedp.Run(ctx,
           chromedp.Navigate(<span class=3D"hljs-string">"https://scrapingc=
lub.com/exercise/list_infinite_scroll/"</span>),
           chromedp.Evaluate(scrollingScript, nil),
           chromedp.Sleep(<span class=3D"hljs-number">5000</span>*time.Mill=
isecond),
           chromedp.Nodes(<span class=3D"hljs-string">".post"</span>, &amp;=
productNodes, chromedp.ByQueryAll),
        )
        <span class=3D"hljs-keyword">if</span> err !=3D nil {
           log.Fatal(<span class=3D"hljs-string">"Error:"</span>, err)
        }
   =20
        <span class=3D"hljs-comment">// scraping logic</span>
        <span class=3D"hljs-keyword">var</span> name, price string
        <span class=3D"hljs-keyword">for</span> _, <span class=3D"hljs-attr=
">node</span> :=3D range productNodes {
           <span class=3D"hljs-comment">// extract data from the product HT=
ML node</span>
           err =3D chromedp.Run(ctx,
              chromedp.Text(<span class=3D"hljs-string">"h4"</span>, &amp;n=
ame, chromedp.ByQuery, chromedp.FromNode(node)),
              chromedp.Text(<span class=3D"hljs-string">"h5"</span>, &amp;p=
rice, chromedp.ByQuery, chromedp.FromNode(node)),
           )
   =20
           <span class=3D"hljs-keyword">if</span> err !=3D nil {
              log.Fatal(<span class=3D"hljs-string">"Error:"</span>, err)
           }
   =20
           <span class=3D"hljs-comment">// initialize a new product instanc=
e</span>
           <span class=3D"hljs-comment">// with scraped data</span>
           <span class=3D"hljs-attr">product</span> :=3D Product{}
           product.name =3D name
           product.price =3D price
   =20
           products =3D append(products, product)
        }
   =20
        fmt.Println(products)
    }
</code></pre>
